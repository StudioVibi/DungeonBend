def catoon_preset_css() -> String:
  "
  .bc-btn-catoon--yellow {
    --bc-catoon-image: url(\"assets/ui/menu/button/button-main-yellow.png\");
    --bc-catoon-text: #fffdf4;
    --bc-catoon-disabled-text: #fff9ea;
  }

  .bc-btn-catoon--dark {
    --bc-catoon-image: url(\"assets/ui/menu/button/button-main-gray.png\");
    --bc-catoon-small-image: url(\"assets/ui/menu/button/button-main-small-gray.png\");
    --bc-catoon-text: #ffffff;
    --bc-catoon-disabled-text: #f5f7fa;
  }
  "
