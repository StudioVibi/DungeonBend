# Public inline inspector config for buttons.
#
# All fields stay visible at the call site and use concrete values only.

type Config {
  button{
    text: String,
    icon: Midum/Button/Icon,
    shape: Midum/Button/Shape,
    size: Midum/Button/Size,
    width: Midum/Button/Width,
    state: Midum/Button/State,
  }
}
