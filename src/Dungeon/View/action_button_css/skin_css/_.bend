def action_button_skin_css() -> String:
  "
  .db-action-button-wrap--primary {
    --db-action-button-image: url(\"assets/ui/menu/button/button-main-yellow.png\");
    --db-action-button-text: #fffdf4;
    --db-action-button-disabled-text: #fff9ea;
  }

  .db-action-button-wrap--secondary {
    --db-action-button-image: url(\"assets/ui/menu/button/button-main-gray.png\");
    --db-action-button-small-image: url(\"assets/ui/menu/button/button-main-small-gray.png\");
    --db-action-button-text: #ffffff;
    --db-action-button-disabled-text: #f5f7fa;
  }

  .db-action-button-wrap--back {
    --db-action-button-image: var(--db-action-button-small-image);
  }
  "
